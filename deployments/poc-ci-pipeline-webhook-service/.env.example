# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.2

# GitHub Configuration
# IMPORTANT: Token must have 'repo' scope (full control of private repositories)
# For fine-grained tokens: Grant "Read and Write" access to Contents and Pull Requests
# Get token from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-personal-access-token-here
# GITHUB_ORG is your GitHub username (for personal repos) or organization name
# Example: If your repo is https://github.com/johndoe/myrepo, use GITHUB_ORG=johndoe
GITHUB_ORG=your-github-username

# Application Configuration
# CLONE_DIRECTORY will use system temp directory if not specified (cross-platform)
# CLONE_DIRECTORY=/custom/path/to/repos  # Optional: customize clone location
LOG_LEVEL=INFO
SERVICE_PORT=8000
MAX_FILES_TO_MODIFY=3
