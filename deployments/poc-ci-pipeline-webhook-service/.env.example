# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
# Chat Completions model (e.g. gpt-4o, gpt-4o-mini). Legacy "gpt-4" is remapped to gpt-4o at runtime.
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# GitHub Configuration
# IMPORTANT: Token must have 'repo' scope (full control of private repositories)
# For fine-grained tokens: Grant "Read and Write" access to Contents and Pull Requests
# Get token from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your-github-personal-access-token-here
GITHUB_TIMEOUT=30

# Application Configuration
LOG_LEVEL=INFO
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
CLONE_DIRECTORY=/tmp/self-healing-webhook
MAX_FILES_TO_MODIFY=3

# Webhook Security (Optional — use one or both)
# WEBHOOK_SECRET = shared HMAC key (NOT a pre-computed signature). Each POST must include header:
#   X-Webhook-Signature: hex(HMAC-SHA256(WEBHOOK_SECRET, raw request body))
# Grafana cannot compute that per request; use WEBHOOK_API_KEY for Grafana instead.
WEBHOOK_SECRET=
# WEBHOOK_API_KEY = static secret; send the same value in X-Api-Key, X-Webhook-Token, or Authorization: Bearer
WEBHOOK_API_KEY=
